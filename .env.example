# ── Supabase (used by desktop, CLI, and Edge Functions) ─────────────────
SUPABASE_URL=https://frwozbjygsxiapaselen.supabase.co
SUPABASE_ANON_KEY=
# Set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_SERVICE_ROLE_KEY=

# ── NVIDIA NIM API ────────────────────────────────────────────────────────
# Set via: supabase secrets set NVIDIA_API_KEY=...
NVIDIA_API_KEY=
# Backup key — used automatically if primary is rate-limited or overloaded
NVIDIA_API_KEY_BACKUP=

# ── Desktop / CLI ─────────────────────────────────────────────────────────
# Base URL for Supabase Edge Functions
PNEUMA_API_URL=https://frwozbjygsxiapaselen.supabase.co/functions/v1
# Stable device identifier (generate once per device: crypto.randomUUID())
PNEUMA_DEVICE_ID=
